# Application Settings
APP_NAME="Solar Parks Analysis API"
APP_VERSION=1.0.0
DEBUG=true

# Authentication
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default Credentials (for demo purposes)
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=admin

# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=solar_parks
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# File Storage
DATA_DIR=./data

# Geospatial Settings
INDIA_PROJECTED_CRS=24378
MAX_DISTANCE_CONSIDERED=5000

# NASA Earthdata credentials for DEM download (required for slopes layer)
# Register at: https://urs.earthdata.nasa.gov/users/new
EARTHDATA_USERNAME=your_earthdata_username
EARTHDATA_PASSWORD=your_earthdata_password
